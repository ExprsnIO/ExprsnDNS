# ═══════════════════════════════════════════════════════════════════════
# ExprsnDNS – Monorepo Environment
# ═══════════════════════════════════════════════════════════════════════

NODE_ENV=development

# ── Shared ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=exprsn
DB_PASSWORD=exprsn
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_SECRET=change-me-in-production
LOG_LEVEL=info

# ── @exprsn/dns ─────────────────────────────────────────────────────────
DNS_APP_NAME=Exprsn DNS
DNS_API_HOST=0.0.0.0
DNS_API_PORT=3053
DNS_BASE_URL=http://localhost:3053
DNS_TRUST_PROXY=false
DNS_BODY_LIMIT=1mb

DNS_DB_NAME=exprsn_dns
DNS_DB_SYNC=false
DNS_DB_LOGGING=false

DNS_REDIS_DB=3
DNS_REDIS_PREFIX=exprsn:dns:

DNS_UDP_ENABLED=true
DNS_UDP_HOST=0.0.0.0
DNS_UDP_PORT=53
DNS_TCP_ENABLED=true
DNS_TCP_HOST=0.0.0.0
DNS_TCP_PORT=53

DNS_DOH_ENABLED=false
DNS_DOH_PATH=/dns-query
DNS_DOT_ENABLED=false
DNS_DOT_PORT=853
DNS_DOT_CERT_PATH=
DNS_DOT_KEY_PATH=

DNS_DEFAULT_TTL=3600
DNS_MINIMUM_TTL=300
DNS_MAXIMUM_TTL=604800
DNS_NEGATIVE_TTL=300

DNS_SOA_REFRESH=3600
DNS_SOA_RETRY=1800
DNS_SOA_EXPIRE=604800
DNS_SOA_MINIMUM=300
DNS_SOA_PRIMARY_NS=ns1.exprsn.local
DNS_SOA_ADMIN_EMAIL=hostmaster.exprsn.local

DNS_RECURSION_ENABLED=false
DNS_RECURSION_UPSTREAM=1.1.1.1,8.8.8.8

DNS_DNSSEC_ENABLED=false
DNS_DNSSEC_ALGORITHM=RSASHA256

DNS_CACHE_ENABLED=true
DNS_CACHE_TTL=300
DNS_CACHE_MAX_ENTRIES=10000

DNS_RATELIMIT_ENABLED=true
DNS_RATELIMIT_QPS=50
DNS_RATELIMIT_BURST=100

DNS_REQUIRE_AUTH=true
DNS_JWT_ISSUER=exprsn-auth
DNS_JWT_AUDIENCE=exprsn-dns
DNS_JWT_ALGORITHMS=HS256,RS256
DNS_CORS_ORIGIN=*
DNS_CORS_CREDENTIALS=false
DNS_API_RATE_WINDOW=60000
DNS_API_RATE_MAX=120
DNS_TSIG_ENABLED=false
DNS_QUERY_LOG_ENABLED=true
DNS_QUERY_LOG_SAMPLE=1.0

# ── Service URLs (cross-service calls) ─────────────────────────────────
EXPRSN_CA_URL=http://localhost:3001
EXPRSN_CA_ENABLED=true
EXPRSN_AUTH_URL=http://localhost:3002
EXPRSN_AUTH_ENABLED=true

# ── @exprsn/ca (see src/exprsn-ca for the full list) ────────────────────
CA_APP_NAME=Exprsn CA
CA_PORT=3001
CA_DB_NAME=exprsn_ca
CA_REDIS_DB=1

# ── @exprsn/auth (see src/exprsn-auth for the full list) ────────────────
AUTH_APP_NAME=Exprsn Auth
AUTH_PORT=3002
AUTH_DB_NAME=exprsn_auth
AUTH_REDIS_DB=2
